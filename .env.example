# ============================================================
# JiraBot — Environment Variables
# Copy file này thành .env và điền thông tin thực tế
# KHÔNG commit file .env lên Git!
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Tài khoản Admin mặc định ────────────────────────────────
# Chỉ dùng khi khởi động lần đầu (DB chưa có user nào).
# Sau khi đã có user, các thay đổi phải qua UI.
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ilovecds
ADMIN_FULLNAME=Administrator
ADMIN_DEPARTMENT=IT

# ── Jira credentials của Admin ───────────────────────────────
# Lấy API Token tại: https://id.atlassian.com/manage-profile/security/api-tokens
# Cloud ID: https://your-domain.atlassian.net/_edge/tenant_info
# Account ID: xem trong profile Atlassian của bạn
ATLASSIAN_TOKEN=your-api-token-here
ATLASSIAN_CLOUD_ID=your-cloud-id-here
ATLASSIAN_ACCOUNT_ID=your-account-id-here
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net
