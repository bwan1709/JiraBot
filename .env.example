# ============================================================
# JiraBot — Environment Variables Template
# Copy file này thành .env và điền thông tin thực tế
# ============================================================

# Server port
PORT=3000

# Node environment
NODE_ENV=production

# ============================================================
# LƯU Ý: Thông tin Atlassian (token, cloud_id, account_id...)
# hiện được quản lý per-user trong SQLite database.
# Mỗi user tự cập nhật trong giao diện "⚙️ Cài đặt cá nhân".
# File .env này chỉ cần PORT và NODE_ENV.
