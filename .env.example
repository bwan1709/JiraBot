# Atlassian credentials
# Lấy API token tại: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_TOKEN=YOUR_API_TOKEN_HERE

# Jira Cloud info
# Cloud ID: lấy từ https://your-domain.atlassian.net/_edge/tenant_info
ATLASSIAN_CLOUD_ID=your-cloud-id
ATLASSIAN_ACCOUNT_ID=your-account-id
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net

PORT=3000
