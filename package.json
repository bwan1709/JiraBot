{
  "name": "jirabot",
  "version": "1.0.0",
  "description": "JiraBot — Time Spent Tracking Dashboard (React + Ant Design + Express/SQLite)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "cross-env PORT=3344 node server.js",
    "client": "vite",
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,magenta \"cross-env PORT=3344 node server.js\" \"cross-env VITE_API_TARGET=http://localhost:3344 vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/charts": "^2.2.3",
    "@ant-design/icons": "^5.5.1",
    "antd": "^5.21.6",
    "better-sqlite3": "^12.10.0",
    "dayjs": "^1.11.13",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
