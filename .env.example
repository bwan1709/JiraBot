# ============================================================
# JiraBot — Configuration Template
# Đây là file template — KHÔNG chứa thông tin thực tế
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3344
NODE_ENV=production

# ── Tài khoản Admin mặc định ────────────────────────────────
# Chỉ dùng khi lần đầu khởi động (DB chưa có user nào)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ilovecds
ADMIN_FULLNAME=Administrator
ADMIN_DEPARTMENT=IT

# ── Jira credentials của Admin ───────────────────────────────
# Lấy API Token: https://id.atlassian.com/manage-profile/security/api-tokens
# Cloud ID: https://your-domain.atlassian.net/_edge/tenant_info
ATLASSIAN_TOKEN=your-api-token-here
ATLASSIAN_CLOUD_ID=your-cloud-id-here
ATLASSIAN_ACCOUNT_ID=your-account-id-here
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net
